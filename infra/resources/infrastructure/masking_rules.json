{
  "masking_rules": {
    "pii_financial_number": {
      "tag": "PII_FINANCIAL",
      "allowed_values": [
        "ARR"
      ],
      "data_type": "NUMBER(18,2)",
      "mask_expression": "NULL",
      "policy_name": "MASK_PII_FINANCIAL_NUMBER",
      "comment": "Financial PII (ARR) - fully masked below exempt roles",
      "is_active": true
    },
    "pii_contact_email": {
      "tag": "PII_CONTACT",
      "allowed_values": [
        "EMAIL"
      ],
      "data_type": "VARCHAR",
      "mask_expression": "REGEXP_REPLACE(VAL, '^[^@]+', '****')",
      "policy_name": "MASK_PII_CONTACT_VARCHAR",
      "comment": "Contact PII (email) - mask local part; extensibility example",
      "is_active": false
    },
    "pii_phone_number": {
      "tag": "PII_PHONE",
      "allowed_values": [
        "PHONE"
      ],
      "data_type": "VARCHAR",
      "mask_expression": "'***-***-' || RIGHT(VAL, 4)",
      "policy_name": "MASK_PII_PHONE_VARCHAR",
      "comment": "Phone PII - show last 4 only; second tag added purely via CSV",
      "is_active": false
    }
  }
}
